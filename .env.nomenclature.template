# ENVIRONMENT VARIABLES - STANDARD NOMENCLATURE
# NO-HUMAN-IN-LOOP Compatible
# Used by: Studio-AI, GitHub Actions, Vercel Deploy
# Pattern: [SERVICE]_[TYPE]_[SCOPE]

# === EXTERNAL APIs ===
OPENAI_API_KEY=sk-YOUR_KEY_HERE
OPENAI_MODEL=gpt-4-turbo

GOOGLEMAP_API_KEY=YOUR_KEY_HERE
GOOGLEMAP_PROJECT_ID=your-gcp-project

# === DATABASE ===
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_KEY_HERE

# === AUTHENTICATION ===
AUTH_SECRET=your_secret_hash_here_min_32chars
AUTH_JWT_SECRET=your_jwt_secret_here
SESSION_TIMEOUT_MINUTES=60

# === ENTITY ROLES (Governance) ===
ENTITY_HERR_KUNSTLER_ROLE=content-creator
ENTITY_HERR_INGENIEUR_ROLE=system-admin
ENTITY_SYSTEM_ADMIN_ROLE=full-access

# === DATABASE URLS ===
DATABASE_URL=postgresql://user:pass@localhost:5432/db
REDIS_URL=redis://localhost:6379

# === DEPLOYMENT ===
VERCEL_PROJECT_ID=YOUR_PROJECT_ID
VERCEL_TOKEN=YOUR_TOKEN_HERE
VERCEL_ENVIRONMENT=production

# === APPLICATION ===
APP_ENV=development
APP_URL=http://localhost:3000
APP_SECRET=secret_key_min_32_chars
LOG_LEVEL=info

# === STORAGE (if using file storage) ===
STORAGE_PROVIDER=supabase
STORAGE_BUCKET=documents

# === GOVERNANCE CONFIG (JSON-stringified) ===
ORG_OS_CONFIG_JSON='{"entities":["herr-kunstler","herr-ingenieur","system-admin"],"workflows":{"task":"voice-input|email|manual","approval":"2-level"}}'
